            "index": 0
          }
        ]
      ]
    },
    "Email (Notify Team)": {
      "main": [
        [
          {
            "node": "Email (Auto-Reply to Customer)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Email (Auto-Reply to Customer)": {
      "main": [
        [
          {
            "node": "Response Data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Response Data": {
      "main": [
        [
          {
            "node": "Respond to Webhook",
