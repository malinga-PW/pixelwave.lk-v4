# n8n Webhook URL (self-hosted or cloud)
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://n8n.pixelwave.lk/webhook

# API Base URL (for image loading, if using Strapi/CMS)
NEXT_PUBLIC_API_BASE_URL=

# Supabase (n8n backend - service role key)
SUPABASE_URL=http://your-supabase-kong-url:8000
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase (Next.js frontend - anon key)
NEXT_PUBLIC_SUPABASE_URL=http://your-supabase-kong-url:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
